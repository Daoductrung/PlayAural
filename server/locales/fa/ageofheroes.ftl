# Age of Heroes - پیام‌های بازی
# یک بازی کارتی ساخت تمدن برای ۲ تا ۶ بازیکن

# نام بازی
game-name-ageofheroes = عصر قهرمانان

# قبایل
ageofheroes-tribe-egyptians = مصریان
ageofheroes-tribe-romans = رومیان
ageofheroes-tribe-greeks = یونانیان
ageofheroes-tribe-babylonians = بابلیان
ageofheroes-tribe-celts = سلت‌ها
ageofheroes-tribe-chinese = چینی‌ها

# منابع ویژه (برای بناهای تاریخی)
ageofheroes-special-limestone = سنگ آهک
ageofheroes-special-concrete = بتن
ageofheroes-special-marble = مرمر
ageofheroes-special-bricks = آجر
ageofheroes-special-sandstone = ماسه‌سنگ
ageofheroes-special-granite = گرانیت

# منابع استاندارد
ageofheroes-resource-iron = آهن
ageofheroes-resource-wood = چوب
ageofheroes-resource-grain = غلات
ageofheroes-resource-stone = سنگ
ageofheroes-resource-gold = طلا

# رویدادها
ageofheroes-event-population-growth = رشد جمعیت
ageofheroes-event-earthquake = زلزله
ageofheroes-event-eruption = فوران آتشفشان
ageofheroes-event-hunger = قحطی
ageofheroes-event-barbarians = بربرها
ageofheroes-event-olympics = بازی‌های المپیک
ageofheroes-event-hero = قهرمان
ageofheroes-event-fortune = بخت

# ساختمان‌ها
ageofheroes-building-army = ارتش
ageofheroes-building-fortress = دژ
ageofheroes-building-general = ژنرال
ageofheroes-building-road = جاده
ageofheroes-building-city = شهر

# اقدامات
ageofheroes-action-tax-collection = جمع‌آوری مالیات
ageofheroes-action-construction = ساخت‌وساز
ageofheroes-action-war = جنگ
ageofheroes-action-do-nothing = هیچ کاری نکن
ageofheroes-play = بازی کن
ageofheroes-play-card-label = بازی { $card }
ageofheroes-card-count = { $count } { $card }
ageofheroes-player-tribe = { $player } ({ $tribe })
ageofheroes-player-tribe-direction = { $player } ({ $tribe }) - { $direction }

# اهداف جنگ
ageofheroes-war-conquest = فتح
ageofheroes-war-plunder = غارت
ageofheroes-war-destruction = ویرانی

# گزینه‌های بازی
ageofheroes-set-victory-cities = شهرهای پیروزی: { $cities }
ageofheroes-enter-victory-cities = تعداد شهرهای لازم برای پیروزی را وارد کنید (۳-۷)
ageofheroes-set-victory-monument = تکمیل بنا: { $progress }%
ageofheroes-set-max-hand = حداکثر تعداد کارت در دست: { $cards } کارت

# اعلان‌های تغییر گزینه
ageofheroes-option-changed-victory-cities = برای پیروزی به { $cities } شهر نیاز است.
ageofheroes-desc-victory-cities = تعداد شهرهایی که یک طرف برای پیروزی در عصر قهرمانان باید کنترل کند (پیش‌فرض ۵، محدوده ۳-۷).
ageofheroes-option-changed-victory-monument = آستانه‌ی تکمیل بنا روی { $progress }% تنظیم شد.
ageofheroes-option-changed-max-hand = حداکثر تعداد کارت در دست روی { $cards } کارت تنظیم شد.

# مرحله‌ی تنظیم
ageofheroes-setup-start = شما رهبر قبیله‌ی { $tribe } هستید. منبع ویژه‌ی بنای تاریخی شما { $special } است. برای تعیین ترتیب نوبت‌ها، تاس بیندازید.
ageofheroes-setup-viewer = بازیکنان در حال انداختن تاس برای تعیین ترتیب نوبت‌ها هستند.
ageofheroes-roll-dice = تاس بیندازید
ageofheroes-war-roll-dice = تاس بیندازید
ageofheroes-dice-result = شما { $total } انداختید ({ $die1 } + { $die2 }).
ageofheroes-dice-result-other = { $player } { $total } انداخت.
ageofheroes-dice-tie = چند بازیکن با { $total } مساوی شدند. دوباره انداختن...
ageofheroes-first-player = { $player } با { $total } بیشترین امتیاز را آورد و اول می‌رود.
ageofheroes-first-player-you = با { $total } امتیاز، شما اول می‌روید.
ageofheroes-whose-turn-setup = مرحله‌ی تنظیم. منتظر { $players } برای انداختن تاس و تعیین ترتیب نوبت‌ها.
ageofheroes-whose-turn-setup-resolving = مرحله‌ی تنظیم. همه‌ی تاس‌ها انداخته شده‌اند؛ ترتیب نوبت‌ها در حال تعیین است.
ageofheroes-whose-turn-prepare = مرحله‌ی آماده‌سازی. رویدادها و بلایا در حال اجرا هستند.
ageofheroes-whose-turn-fair = مرحله‌ی بازار. { $players } هنوز می‌توانند مبادله کنند.
ageofheroes-whose-turn-fair-resolving = مرحله‌ی بازار. مبادلات در حال انجام است.
ageofheroes-whose-turn-road = مرحله‌ی اجازه‌ی جاده. { $responder } باید به درخواست جاده‌ی { $requester } پاسخ دهد.
ageofheroes-whose-turn-olympics = جنگ اعلام شده. { $defender } باید تصمیم بگیرد که از بازی‌های المپیک علیه { $attacker } استفاده کند یا نه.
ageofheroes-whose-turn-war-attack = آماده‌سازی جنگ. { $attacker } در حال انتخاب نیروهای خود علیه { $defender } است.
ageofheroes-whose-turn-war-defense = آماده‌سازی جنگ. { $defender } در حال انتخاب نیروهای دفاعی خود علیه { $attacker } است.
ageofheroes-whose-turn-war-roll = مرحله‌ی نبرد. منتظر { $players } برای انداختن تاس.
ageofheroes-whose-turn-game-over = بازی تمام شد.

# مرحله‌ی آماده‌سازی
ageofheroes-prepare-start = بازیکنان باید کارت‌های رویداد را بازی کنند و بلایا را دور بیندازند.
ageofheroes-prepare-your-turn = شما { $count } { $count ->
    [one] کارت
    *[other] کارت
} برای بازی یا دور انداختن دارید.
ageofheroes-prepare-done = مرحله‌ی آماده‌سازی کامل شد.

# رویدادهای بازی/دور انداخته شده
ageofheroes-population-growth = { $player } رشد جمعیت را بازی می‌کند و یک شهر جدید می‌سازد.
ageofheroes-population-growth-you = شما رشد جمعیت را بازی می‌کنید و یک شهر جدید می‌سازید.
ageofheroes-discard-card = { $player } { $card } را دور می‌اندازد.
ageofheroes-discard-card-you = شما { $card } را دور می‌اندازید.
ageofheroes-earthquake = زلزله‌ای به قبیله‌ی { $player } می‌زند؛ ارتش‌های آنها به حالت بازیابی می‌روند.
ageofheroes-earthquake-you = زلزله‌ای به قبیله‌ی شما می‌زند؛ ارتش‌های شما به حالت بازیابی می‌روند.
ageofheroes-eruption = یک فوران آتشفشانی یکی از شهرهای { $player } را نابود می‌کند.
ageofheroes-eruption-you = یک فوران آتشفشانی یکی از شهرهای شما را نابود می‌کند.

# اثرات بلایا
ageofheroes-hunger-strikes = قحطی رخ می‌دهد.
ageofheroes-lose-card-hunger = شما { $card } را از دست می‌دهید.
ageofheroes-barbarians-pillage = بربرها به منابع { $player } حمله می‌کنند.
ageofheroes-barbarians-attack = بربرها به منابع { $player } حمله می‌کنند.
ageofheroes-barbarians-attack-you = بربرها به منابع شما حمله می‌کنند.
ageofheroes-lose-card-barbarians = شما { $card } را از دست می‌دهید.
ageofheroes-block-with-card = { $player } با استفاده از { $card } بلا را مسدود می‌کند.
ageofheroes-block-with-card-you = شما با استفاده از { $card } بلا را مسدود می‌کنید.

# کارت‌های بلا با هدف مشخص (زلزله/فوران)
ageofheroes-select-disaster-target = هدفی برای { $card } انتخاب کنید.
ageofheroes-no-targets = هیچ هدف معتبری در دسترس نیست.
ageofheroes-earthquake-strikes-you = { $attacker } زلزله را علیه شما بازی می‌کند. ارتش‌های شما غیرفعال شدند.
ageofheroes-earthquake-strikes = { $attacker } زلزله را علیه { $player } بازی می‌کند.
ageofheroes-armies-disabled = { $count } { $count ->
    [one] ارتش
    *[other] ارتش
} برای یک نوبت غیرفعال شدند.
ageofheroes-eruption-strikes-you = { $attacker } فوران را علیه شما بازی می‌کند. یکی از شهرهای شما نابود شد.
ageofheroes-eruption-strikes = { $attacker } فوران را علیه { $player } بازی می‌کند.
ageofheroes-city-destroyed = یک شهر بر اثر فوران نابود شد.

# مرحله‌ی بازار
ageofheroes-fair-start = روز در بازارگاه آغاز می‌شود.
ageofheroes-fair-draw-base = شما { $count } { $count ->
    [one] کارت
    *[other] کارت
} می‌کشید.
ageofheroes-fair-draw-roads = شما به لطف شبکه‌ی جاده‌های خود { $count } { $count ->
    [one] کارت اضافی
    *[other] کارت اضافی
} می‌کشید.
ageofheroes-fair-draw-other = { $player } { $count } { $count ->
    [one] کارت
    *[other] کارت
} می‌کشد.

# مبادله/حراج
ageofheroes-auction-start = حراج آغاز می‌شود.
ageofheroes-offer-trade = پیشنهاد مبادله
ageofheroes-offer-made = { $player } { $card } را در ازای { $wanted } پیشنهاد می‌دهد.
ageofheroes-offer-made-you = شما { $card } را در ازای { $wanted } پیشنهاد می‌دهید.
ageofheroes-trade-accepted = { $player } پیشنهاد { $other } را می‌پذیرد و { $give } را با { $receive } مبادله می‌کند.
ageofheroes-trade-accepted-you = شما پیشنهاد { $other } را می‌پذیرید و { $receive } را دریافت می‌کنید.
ageofheroes-trade-cancelled = { $player } پیشنهاد خود برای { $card } را پس می‌گیرد.
ageofheroes-trade-cancelled-you = شما پیشنهاد خود برای { $card } را پس می‌گیرید.
ageofheroes-stop-trading = توقف مبادله
ageofheroes-select-request = شما { $card } را پیشنهاد می‌دهید. در مقابل چه می‌خواهید؟
ageofheroes-cancel = انصراف
ageofheroes-left-auction = { $player } خارج شد.
ageofheroes-left-auction-you = شما از بازارگاه خارج شدید.
ageofheroes-already-left-auction = شما قبلاً از بازارگاه خارج شده‌اید.
ageofheroes-any-card = هر کارتی
ageofheroes-cannot-trade-own-special = شما نمی‌توانید منبع ویژه‌ی بنای تاریخی خود را مبادله کنید.
ageofheroes-resource-not-in-game = این منبع ویژه در این بازی استفاده نمی‌شود.

# مرحله‌ی اصلی بازی
ageofheroes-play-start = مرحله‌ی بازی.
ageofheroes-day = روز { $day }
ageofheroes-draw-card = { $player } یک کارت از دسته می‌کشد.
ageofheroes-draw-card-you = شما { $card } را از دسته می‌کشید.
ageofheroes-draw-card-brief = { $player } می‌کشد.
ageofheroes-draw-card-you-brief = کشیدن: { $card }.
ageofheroes-your-action = چه کاری می‌خواهید انجام دهید؟
ageofheroes-your-action-brief = اقدام؟

# جمع‌آوری مالیات
ageofheroes-tax-collection = { $player } جمع‌آوری مالیات را انتخاب می‌کند: { $cities } { $cities ->
    [one] شهر
    *[other] شهر
} { $cards } { $cards ->
    [one] کارت
    *[other] کارت
} جمع‌آوری می‌کند.
ageofheroes-tax-collection-you = شما جمع‌آوری مالیات را انتخاب می‌کنید: { $cities } { $cities ->
    [one] شهر
    *[other] شهر
} { $cards } { $cards ->
    [one] کارت
    *[other] کارت
} جمع‌آوری می‌کند.
ageofheroes-tax-collection-brief = مالیات { $player }: { $cards } از { $cities }.
ageofheroes-tax-collection-you-brief = مالیات: { $cards } از { $cities }.
ageofheroes-tax-no-city = جمع‌آوری مالیات: شما هیچ شهری ندارید. یک کارت را دور بیندازید تا یک کارت جدید بکشید.
ageofheroes-tax-no-city-done = { $player } جمع‌آوری مالیات را انتخاب می‌کند اما شهری ندارد، بنابراین یک کارت را عوض می‌کند.
ageofheroes-tax-no-city-done-you = جمع‌آوری مالیات: شما { $card } را با یک کارت جدید عوض کردید.

# ساخت‌وساز
ageofheroes-construction-menu = چه چیزی می‌خواهید بسازید؟
ageofheroes-construction-done = { $player } { $building } ساخت.
ageofheroes-construction-done-you = شما { $building } ساختید.
ageofheroes-build-cost-resource = { $count ->
    [one] { $resource }
    *[other] { $count }x { $resource }
}
ageofheroes-build-menu-label = { $building } ({ $cost })
ageofheroes-construction-stop = توقف ساخت
ageofheroes-construction-stopped = شما تصمیم به توقف ساخت گرفتید.
ageofheroes-road-select-neighbor = انتخاب کنید به کدام همسایه جاده بسازید.
ageofheroes-direction-left = سمت چپ شما
ageofheroes-direction-right = سمت راست شما
ageofheroes-road-request-sent = درخواست جاده ارسال شد. منتظر تأیید همسایه.
ageofheroes-road-request-received = { $requester } درخواست اجازه برای ساخت جاده به قبیله‌ی شما می‌دهد.
ageofheroes-road-request-denied-you = شما درخواست جاده را رد کردید.
ageofheroes-road-request-denied = { $denier } درخواست جاده‌ی شما را رد کرد.
ageofheroes-road-built = { $tribe1 } و { $tribe2 } اکنون با جاده به هم متصل هستند.
ageofheroes-road-no-target = هیچ قبیله‌ی همسایه‌ای برای ساخت جاده در دسترس نیست.
ageofheroes-approve = تأیید
ageofheroes-deny = رد
ageofheroes-supply-exhausted = دیگر { $building } برای ساخت موجود نیست.

# هیچ کاری نکن
ageofheroes-do-nothing = { $player } می‌گذرد.
ageofheroes-do-nothing-you = شما می‌گذرید...
ageofheroes-do-nothing-brief = { $player } می‌گذرد.
ageofheroes-do-nothing-you-brief = گذشت.
ageofheroes-confirm-do-nothing = گذشتن، اقدام شما را برای این نوبت رد می‌کند. برای تأیید دوباره "هیچ کاری نکن" را فشار دهید.

# جنگ
ageofheroes-war-declare = { $attacker } به { $defender } اعلام جنگ می‌کند. هدف: { $goal }.
ageofheroes-war-prepare = ارتش‌های خود را برای { $action } انتخاب کنید.
ageofheroes-war-no-army = شما هیچ ارتش یا کارت قهرمانی در دسترس ندارید.
ageofheroes-war-no-tribe = شما در این نبرد قبیله‌ای ندارید.
ageofheroes-war-no-targets = هیچ هدف معتبری برای جنگ وجود ندارد.
ageofheroes-war-no-valid-goal = هیچ هدف جنگی معتبری علیه این هدف وجود ندارد.
ageofheroes-war-invalid-forces = این نیروها دیگر معتبر نیستند. ارتش‌ها، ژنرال‌ها و کارت‌های قهرمان موجود خود را بررسی کنید.
ageofheroes-war-select-target = انتخاب کنید به کدام بازیکن حمله کنید.
ageofheroes-war-select-goal = هدف جنگی خود را انتخاب کنید.
ageofheroes-war-prepare-attack = نیروهای حمله‌کننده‌ی خود را انتخاب کنید.
ageofheroes-war-prepare-defense = { $attacker } به شما حمله می‌کند؛ نیروهای دفاعی خود را انتخاب کنید.
ageofheroes-war-force-add-armies = یک ارتش اضافه کنید. ارتش‌های تعهدشده: { $current } از { $max }.
ageofheroes-war-force-remove-armies = یک ارتش حذف کنید. ارتش‌های تعهدشده: { $current } از { $max }.
ageofheroes-war-force-add-generals = یک ژنرال اضافه کنید. ژنرال‌های تعهدشده: { $current } از { $max }.
ageofheroes-war-force-remove-generals = یک ژنرال حذف کنید. ژنرال‌های تعهدشده: { $current } از { $max }.
ageofheroes-war-force-add-hero-armies = یک قهرمان به عنوان ارتش اضافه کنید. ارتش‌های قهرمان تعهدشده: { $current } از { $max }.
ageofheroes-war-force-remove-hero-armies = یک ارتش قهرمان حذف کنید. ارتش‌های قهرمان تعهدشده: { $current } از { $max }.
ageofheroes-war-force-add-hero-generals = یک قهرمان به عنوان ژنرال اضافه کنید. ژنرال‌های قهرمان تعهدشده: { $current } از { $max }.
ageofheroes-war-force-remove-hero-generals = یک ژنرال قهرمان حذف کنید. ژنرال‌های قهرمان تعهدشده: { $current } از { $max }.
ageofheroes-war-force-unit-armies = ارتش‌ها
ageofheroes-war-force-unit-generals = ژنرال‌ها
ageofheroes-war-force-unit-hero-armies = ارتش‌های قهرمان
ageofheroes-war-force-unit-hero-generals = ژنرال‌های قهرمان
ageofheroes-war-force-max = قبلاً به حداکثر رسیده‌اید: { $unit } ({ $max }).
ageofheroes-war-force-min = هیچ‌کدام تعهد نشده: { $unit }.
ageofheroes-war-force-updated = نیروهای تعهدشده: { $armies } ارتش، { $generals } ژنرال، { $hero_armies } ارتش قهرمان، { $hero_generals } ژنرال قهرمان.
ageofheroes-war-attack = حمله...
ageofheroes-war-defend = دفاع...
ageofheroes-war-clear-forces = پاک کردن نیروها
ageofheroes-war-prepared = نیروهای شما: { $armies } { $armies ->
    [one] ارتش
    *[other] ارتش
}{ $generals ->
    [0] {""}
    [one] {" و ۱ ژنرال"}
    *[other] { " و " }{ $generals } ژنرال
}{ $heroes ->
    [0] {""}
    [one] {" و ۱ قهرمان"}
    *[other] { " و " }{ $heroes } قهرمان
}.
ageofheroes-war-roll-you = شما { $roll } می‌اندازید.
ageofheroes-war-roll-other = { $player } { $roll } می‌اندازد.
ageofheroes-war-bonuses-you = { $general ->
    [0] { $fortress ->
        [0] {""}
        [1] +۱ از دژ = { $total } مجموع
        *[other] +{ $fortress } از دژها = { $total } مجموع
    }
    *[other] { $fortress ->
        [0] +{ $general } از ژنرال = { $total } مجموع
        [1] +{ $general } از ژنرال، +۱ از دژ = { $total } مجموع
        *[other] +{ $general } از ژنرال، +{ $fortress } از دژها = { $total } مجموع
    }
}
ageofheroes-war-bonuses-other = { $general ->
    [0] { $fortress ->
        [0] {""}
        [1] { $player }: +۱ از دژ = { $total } مجموع
        *[other] { $player }: +{ $fortress } از دژها = { $total } مجموع
    }
    *[other] { $fortress ->
        [0] { $player }: +{ $general } از ژنرال = { $total } مجموع
        [1] { $player }: +{ $general } از ژنرال، +۱ از دژ = { $total } مجموع
        *[other] { $player }: +{ $general } از ژنرال، +{ $fortress } از دژها = { $total } مجموع
    }
}
