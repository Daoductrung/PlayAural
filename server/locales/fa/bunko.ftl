game-name-bunko = بانکو

bunko-roll = انداختن تاس
bunko-check-status = مشاهده‌ی وضعیت
bunko-check-last-roll = مشاهده‌ی آخرین پرتاب

bunko-game-start = بانکو آغاز شد. بازیکنان: { $players }.
bunko-round-start = دور { $round } از { $total_rounds }. عدد هدف برای این دور { $target } است.
bunko-round-start-brief = دور { $round }/{ $total_rounds }. هدف { $target }.
bunko-you-win-round = شما دور { $round } را با { $score } امتیاز در برابر هدف { $target } برنده شدید.
bunko-player-wins-round = { $player } دور { $round } را با { $score } امتیاز در برابر هدف { $target } برنده شد.
bunko-you-win-round-brief = شما دور { $round } را بردید: { $score }.
bunko-player-wins-round-brief = { $player } دور { $round } را برد: { $score }.

bunko-you-roll-match = شما { $dice } انداختید و { $points } { $points ->
    [one] امتیاز
   *[other] امتیاز
} در برابر هدف { $target } کسب کردید. مجموع دور: { $round_total }. امتیاز کل: { $total }.
bunko-player-rolls-match = { $player } { $dice } انداخت و { $points } { $points ->
    [one] امتیاز
   *[other] امتیاز
} در برابر هدف { $target } کسب کرد. مجموع دور: { $round_total }. امتیاز کل: { $total }.
bunko-you-roll-match-brief = شما: { $dice }، +{ $points }. دور { $round_total }؛ کل { $total }.
bunko-player-rolls-match-brief = { $player }: { $dice }، +{ $points }. دور { $round_total }؛ کل { $total }.

bunko-you-roll-mini_bunko = شما { $dice } انداختید و یک بانکوی کوچک کسب کردید چون همه‌ی تاس‌ها با هم برابرند اما با هدف { $target } برابر نیستند، و { $points } امتیاز گرفتید. مجموع دور: { $round_total }. امتیاز کل: { $total }.
bunko-player-rolls-mini_bunko = { $player } { $dice } انداخت و یک بانکوی کوچک کسب کرد چون همه‌ی تاس‌ها با هم برابرند اما با هدف { $target } برابر نیستند، و { $points } امتیاز گرفت. مجموع دور: { $round_total }. امتیاز کل: { $total }.
bunko-you-roll-mini_bunko-brief = شما: بانکوی کوچک { $dice }، +{ $points }. دور { $round_total }؛ کل { $total }.
bunko-player-rolls-mini_bunko-brief = { $player }: بانکوی کوچک { $dice }، +{ $points }. دور { $round_total }؛ کل { $total }.

bunko-you-roll-bunko = شما { $dice } انداختید و یک بانکو کسب کردید: سه عدد هدف { $target } برای { $points } امتیاز. مجموع دور: { $round_total }. امتیاز کل: { $total }.
bunko-player-rolls-bunko = { $player } { $dice } انداخت و یک بانکو کسب کرد: سه عدد هدف { $target } برای { $points } امتیاز. مجموع دور: { $round_total }. امتیاز کل: { $total }.
bunko-you-roll-bunko-brief = شما: بانکو { $dice }، +{ $points }. دور { $round_total }؛ کل { $total }.
bunko-player-rolls-bunko-brief = { $player }: بانکو { $dice }، +{ $points }. دور { $round_total }؛ کل { $total }.

bunko-you-roll-no_score = شما { $dice } انداختید و هیچ امتیازی کسب نکردید چون هیچ‌کدام از تاس‌ها با هدف { $target } برابر نیستند و بانکوی کوچکی هم وجود ندارد. نوبت شما می‌گذرد.
bunko-player-rolls-no_score = { $player } { $dice } انداخت و هیچ امتیازی کسب نکرد چون هیچ‌کدام از تاس‌ها با هدف { $target } برابر نیستند و بانکوی کوچکی هم وجود ندارد. نوبت می‌گذرد.
bunko-you-roll-no_score-brief = شما: { $dice }، ۰. گذشت.
bunko-player-rolls-no_score-brief = { $player }: { $dice }، ۰. گذشت.

bunko-last-roll-none = هنوز در این دور پرتابی انجام نشده است.
bunko-last-roll-match = آخرین پرتاب { $player }: { $dice } و { $points } { $points ->
    [one] امتیاز
   *[other] امتیاز
} در برابر هدف { $target } کسب کرد.
bunko-last-roll-match-you = آخرین پرتاب شما: { $dice } و { $points } { $points ->
    [one] امتیاز
   *[other] امتیاز
} در برابر هدف { $target } کسب کردید.
bunko-last-roll-mini_bunko = آخرین پرتاب { $player }: { $dice } برای یک بانکوی کوچک، { $points } امتیاز کسب کرد چون تاس‌ها با هم برابرند اما با هدف { $target } برابر نیستند.
bunko-last-roll-mini_bunko-you = آخرین پرتاب شما: { $dice } برای یک بانکوی کوچک، { $points } امتیاز کسب کردید چون تاس‌ها با هم برابرند اما با هدف { $target } برابر نیستند.
bunko-last-roll-bunko = آخرین پرتاب { $player }: { $dice } برای یک بانکو: سه عدد هدف { $target }، به ارزش { $points } امتیاز.
bunko-last-roll-bunko-you = آخرین پرتاب شما: { $dice } برای یک بانکو: سه عدد هدف { $target }، به ارزش { $points } امتیاز.
bunko-last-roll-no_score = آخرین پرتاب { $player }: { $dice } و هیچ امتیازی در برابر هدف { $target } کسب نکرد.
bunko-last-roll-no_score-you = آخرین پرتاب شما: { $dice } و هیچ امتیازی در برابر هدف { $target } کسب نکردید.

bunko-status-round = دور { $round } از { $total_rounds }. عدد هدف: { $target }.
bunko-status-turn = بازیکن فعلی: { $player }.
bunko-status-leader = رهبر: { $player } با { $rounds } { $rounds ->
    [one] برد دور
   *[other] برد دور
} و { $total } امتیاز کل.

bunko-standings-header = رده‌بندی. برنده بر اساس { $mode } تعیین می‌شود.
bunko-score-line = { $rank }. { $player }: { $rounds } { $rounds ->
    [one] برد دور
   *[other] برد دور
}، { $total } امتیاز کل، { $current } در این دور، { $bunkos } { $bunkos ->
    [one] بانکو
   *[other] بانکو
}، { $mini_bunkos } { $mini_bunkos ->
    [one] بانکوی کوچک
   *[other] بانکوی کوچک
}

bunko-roll-already-resolving = تاس‌های شما هنوز در حال چرخش هستند. قبل از پرتاب مجدد منتظر نتیجه باشید.
bunko-error-round-count-invalid = بانکو به بین { $min } و { $max } دور نیاز دارد. تنظیم فعلی { $count } است.
bunko-error-winning-mode-invalid = بانکو از حالت برنده‌سازی "{ $mode }" پشتیبانی نمی‌کند. برد دور یا امتیاز کل را انتخاب کنید.

bunko-set-round-count = تعداد دورها: { $count }
bunko-enter-round-count = تعداد دورها را وارد کنید:
bunko-option-changed-round-count = تعداد دورها به { $count } تغییر یافت.
bunko-desc-round-count = تعداد دورهای بانکو که قبل از تعیین برنده بازی می‌شوند (پیش‌فرض ۶، محدوده ۱-۱۲).

bunko-set-winning-mode = حالت برنده‌سازی: { $mode }
bunko-select-winning-mode = حالت برنده‌سازی را انتخاب کنید:
bunko-option-changed-winning-mode = حالت برنده‌سازی به { $mode } تغییر یافت.
bunko-desc-winning-mode = انتخاب می‌کند که برندگان بانکو بر اساس تعداد دورهای برده شده یا امتیاز کل رتبه‌بندی شوند.
bunko-winning-mode-round-wins = برد دور
bunko-winning-mode-total-score = امتیاز کل