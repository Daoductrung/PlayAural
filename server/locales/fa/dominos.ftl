dominos-play-tile = { $tile }
dominos-open-with-tile = شروع با { $tile }
dominos-play-tile-at = بازی { $tile } در { $side }
dominos-play-tile-multi = بازی { $tile } در { $sides }
dominos-select-side = یک سمت انتخاب کنید

