dominos-chain-header = زنجیره
dominos-chain-empty = زنجیره خالی است.
dominos-chain-center = مرکز: { $tile }
dominos-branch-empty = بدون مهره
dominos-chain-branch = { $side }: { $tiles }. انتهای باز { $open_end }.
dominos-boneyard-count = گورستان: { $count } مهره باقی‌مانده.
dominos-end-info = { $side } { $value }

dominos-hand-header = دست شما
dominos-hand-line = { $tile } به ارزش { $points } امتیاز.
dominos-hand-line-playable = { $tile } به ارزش { $points } امتیاز. قابل بازی در { $sides }.
dominos-hand-line-opening-playable = { $tile } به ارزش { $points } امتیاز. می‌توانید از آن برای شروع این دور استفاده کنید.
dominos-hand-total = مجموع پیپ‌های دست: { $pips }.
dominos-player-count = { $player } { $count } مهره دارد
dominos-no-other-players = هیچ بازیکن دیگری وجود ندارد.

