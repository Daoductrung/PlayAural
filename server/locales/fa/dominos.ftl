game-name-dominos = دومینو
dominos-desc-team-mode = به‌صورت انفرادی بازی کنید، یا از هر آرایش تیمی زوج معتبری که با تعداد فعلی بازیکنان مطابقت دارد استفاده کنید.

# گزینه‌ها
dominos-set-target-score = امتیاز هدف: { $score }
dominos-enter-target-score = امتیاز هدف را وارد کنید
dominos-option-changed-target-score = امتیاز هدف روی { $score } تنظیم شد.
dominos-desc-target-score = امتیاز مورد نیاز برای بردن دومینو (پیش‌فرض ۱۰۰، محدوده ۲۰-۵۰۰).

dominos-set-draw-mode = حالت: { $mode }
dominos-select-draw-mode = حالت را انتخاب کنید
dominos-option-changed-draw-mode = حالت روی { $mode } تنظیم شد.
dominos-desc-draw-mode = حالت کشیدن را انتخاب می‌کند، که در آن بازیکنان از گورستان می‌کشند، یا حالت مسدود، که در آن بازیکنان مسدود شده می‌گذرند.

dominos-set-domino-set = مجموعه‌ی دومینو: { $domino_set }
dominos-select-domino-set = مجموعه‌ی دومینو را انتخاب کنید
dominos-option-changed-domino-set = مجموعه‌ی دومینو به { $domino_set } تغییر یافت.
dominos-desc-domino-set = اندازه‌ی مجموعه‌ی دومینو. دابل-۶ تا ۵ بازیکن، دابل-۹ تا ۷ بازیکن، و دابل-۱۲ تا ۱۲ بازیکن را پشتیبانی می‌کند (پیش‌فرض دابل-۶).

dominos-set-spinner = چرخان: { $enabled }
dominos-option-changed-spinner = چرخان روی { $enabled } تنظیم شد.
dominos-desc-spinner-enabled = کنترل می‌کند که آیا دابل آغازین یک چرخان چهارجهته ایجاد می‌کند یا نه (پیش‌فرض روشن).

dominos-set-opening-rule = قانون شروع: { $opening_rule }
dominos-select-opening-rule = قانون شروع را انتخاب کنید
dominos-option-changed-opening-rule = قانون شروع روی { $opening_rule } تنظیم شد.
dominos-desc-opening-rule = نحوه‌ی انتخاب اولین مهره در هر دور دومینو را انتخاب می‌کند.

