dominos-side-left = چپ
dominos-side-right = راست
dominos-side-up = بالا
dominos-side-down = پایین

# اعتبارسنجی و دلایل غیرفعال
dominos-draw-only-mode = کشیدن فقط در حالت کشیدن در دسترس است.
dominos-must-play = شما قبلاً یک مهره‌ی قابل بازی دارید.
dominos-boneyard-empty = گورستان خالی است.
dominos-must-draw = قبل از کوبیدن باید بکشید.
dominos-illegal-side = آن سمت برای مهره‌ی انتخاب‌شده قانونی نیست.
dominos-no-play-for-tile = { $tile } در حال حاضر قابل بازی نیست.
dominos-choose-side-keybind = یک سمت را با کلید جهت انتخاب کنید. طرف‌های قانونی: { $sides }.
dominos-opening-must-play = دور هنوز شروع نشده است. برای شروع زنجیره باید یک مهره انتخاب کنید.
dominos-error-set-too-small = { $players } بازیکن نمی‌توانند به اندازه‌ی کافی مهره از مجموعه‌ی دابل-{ $selected_pip } دریافت کنند. برای این اندازه‌ی میز حداقل دابل-{ $required_pip } را انتخاب کنید.

# گیم‌پلی
dominos-you-open-round = شما این دور را شروع می‌کنید. هر مهره‌ای از دست خود را برای شروع زنجیره انتخاب کنید.
dominos-player-opens-round = { $player } این دور را شروع می‌کند و در حال انتخاب مهره‌ی شروع است.
dominos-you-opened = شما دور را با { $tile } شروع کردید.
dominos-player-opened = { $player } دور را با { $tile } شروع کرد.
dominos-you-opened-spinner = شما دور را با { $tile } شروع کردید و یک چرخان چهارجهته ایجاد کردید.
dominos-player-opened-spinner = { $player } دور را با { $tile } شروع کرد و یک چرخان چهارجهته ایجاد کرد.
dominos-you-drew-single = شما { $tile } را از گورستان کشیدید.
dominos-you-drew-many = شما { $count } مهره از گورستان کشیدید.
dominos-player-drew-single = { $player } ۱ مهره از گورستان کشید.
dominos-player-drew-many = { $player } { $count } مهره از گورستان کشید.
dominos-you-played = شما { $tile } را در شاخه‌ی { $side } بازی کردید.
dominos-you-played-drawn = شما کشیدید و { $tile } را در شاخه‌ی { $side } بازی کردید.
dominos-player-played = { $player } { $tile } را در شاخه‌ی { $side } بازی کرد.
dominos-you-knock = شما کوبیدید چون مهره‌ی قانونی برای بازی ندارید.
dominos-player-knocks = { $player } می‌کوبد.
dominos-you-won-round = شما دست خود را خالی کردید و { $points } امتیاز از مهره‌های حریفان کسب کردید.
dominos-player-won-round = { $player } دست خود را خالی کرد و { $points } امتیاز از مهره‌های حریفان کسب کرد.
dominos-round-blocked-tie = دور مسدود شد. کمترین مجموع پیپ { $pips } است، اما مساوی است. هیچ امتیازی کسب نمی‌شود.
dominos-round-blocked-winner = دور مسدود شد. { $team } با { $pips } کمترین مجموع پیپ را دارد و { $points } امتیاز کسب می‌کند.
dominos-match-tied-continue = چند تیم به { $score } امتیاز رسیدند. بازی تا شکستن تساوی ادامه می‌یابد.
dominos-match-winner = { $team } بازی را با { $score } امتیاز می‌برد.

