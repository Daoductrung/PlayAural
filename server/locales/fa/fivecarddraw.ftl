game-name-fivecarddraw = پوکر پنج کارتی

draw-set-starting-chips = تراشه‌های اولیه: { $count }
draw-enter-starting-chips = تراشه‌های اولیه را وارد کنید
draw-option-changed-starting-chips = تراشه‌های اولیه روی { $count } تنظیم شد.
fivecarddraw-desc-starting-chips = تعداد تراشه‌های اولیه‌ی هر بازیکن در پوکر پنج کارتی، از ۱۰۰ تا ۱٬۰۰۰٬۰۰۰ تراشه. پیش‌فرض: ۲۰٬۰۰۰.

draw-set-ante = آنته: { $count }
draw-enter-ante = مبلغ آنته را وارد کنید
draw-option-changed-ante = آنته روی { $count } تنظیم شد.
fivecarddraw-desc-ante = مبلغ اجباری که هر بازیکن فعال قبل از هر دست پرداخت می‌کند. باید کمتر از تراشه‌های اولیه باشد (پیش‌فرض ۱۰۰، محدوده ۰-۱٬۰۰۰٬۰۰۰ تراشه).

draw-set-turn-timer = زمان‌سنج نوبت: { $mode }
draw-select-turn-timer = زمان‌سنج نوبت را انتخاب کنید
draw-option-changed-turn-timer = زمان‌سنج نوبت روی { $mode } تنظیم شد.
fivecarddraw-desc-turn-timer = محدودیت زمانی اختیاری برای هر تصمیم شرط‌بندی یا تعویض: ۵، ۱۰، ۱۵، ۲۰، ۳۰، ۴۵، ۶۰، یا ۹۰ ثانیه، یا بدون محدودیت. پیش‌فرض: بدون محدودیت.

draw-set-raise-mode = حالت افزایش: { $mode }
draw-select-raise-mode = حالت افزایش را انتخاب کنید
draw-option-changed-raise-mode = حالت افزایش روی { $mode } تنظیم شد.
fivecarddraw-desc-raise-mode = سبک محدودیت افزایش: بدون محدودیت، محدودیت پات، یا محدودیت دوبرابر پات. حالت‌های مبتنی بر پات به آنته بزرگتر از ۰ نیاز دارند تا دور اول شرط‌بندی به‌طور عادی باز شود (پیش‌فرض بدون محدودیت).

draw-set-max-raises = حداکثر افزایش در هر دور شرط‌بندی: { $count }
draw-enter-max-raises = حداکثر افزایش در هر دور شرط‌بندی را وارد کنید (۰ برای بدون محدودیت)
draw-option-changed-max-raises = حداکثر افزایش در هر دور شرط‌بندی روی { $count } تنظیم شد.
fivecarddraw-desc-max-raises = حداکثر افزایش مجاز در یک دور شرط‌بندی، از ۰ تا ۱۰. برای بدون محدودیت، ۰ را تنظیم کنید. پیش‌فرض: ۰.

draw-set-draw-limit = قانون تعویض: { $mode }
draw-select-draw-limit = قانون تعویض را انتخاب کنید
draw-option-changed-draw-limit = قانون تعویض روی { $mode } تنظیم شد.
fivecarddraw-desc-draw-limit = قانون تعویض: تعویض تا ۳ کارت، یا اجازه‌ی تعویض ۴ کارت فقط در صورت نگهداشتن آس. پیش‌فرض: تا ۳ کارت.
draw-limit-three-cards = تا ۳ کارت (استاندارد)
draw-limit-four-with-ace = تا ۴ کارت هنگام نگهداشتن آس

draw-error-ante-too-high = آنته ({ $ante } تراشه) باید کمتر از تراشه‌های اولیه ({ $chips } تراشه) باشد تا بازیکنان همچنان بتوانند پس از پخش کارت‌ها تصمیمات شرط‌بندی بگیرند.
draw-error-capped-mode-needs-ante = { $mode ->
    [pot_limit] محدودیت پات
    [double_pot] محدودیت دوبرابر پات
   *[other] این حالت افزایش محدود
} به آنته بزرگتر از ۰ نیاز دارد تا بازیکن اول مبلغی مبتنی بر پات برای شرط‌بندی در دسترس داشته باشد.

draw-antes-posted = آنته‌ها پرداخت شدند. پات اکنون شامل { $amount } تراشه است.
draw-betting-round-1 = دور شرط‌بندی اول.
draw-betting-round-2 = دور شرط‌بندی دوم.
draw-begin-draw = مرحله‌ی تعویض. از اولین بازیکن فعال سمت چپ فروشنده شروع کنید، کارت‌هایی را برای تعویض انتخاب کنید یا بدون تعویض بمانید.
draw-not-draw-phase = تعویض کارت‌ها فقط پس از دور اول شرط‌بندی در دسترس است. با اقدام شرط‌بندی فعلی ادامه دهید.
draw-not-betting = شرط‌بندی در طول مرحله‌ی تعویض در دسترس نیست. هر کارتی را برای تعویض انتخاب کنید، سپس روی تعویض کارت‌ها کلیک کنید.
draw-fold-not-available = کناره‌گیری در طول مرحله‌ی تعویض در دسترس نیست. هر کارتی را برای تعویض انتخاب کنید، سپس روی تعویض کارت‌ها کلیک کنید.

draw-toggle-discard = انتخاب کارت { $index } برای تعویض
draw-card-keep = { $card }
draw-card-discard = { $card }، انتخاب شده برای تعویض
draw-draw-cards = تعویض کارت‌ها
draw-draw-cards-count = { $count ->
    [0] بدون تعویض
    [one] تعویض ۱ کارت
   *[other] تعویض { $count } کارت
}
draw-dealt-cards = پنج کارت شما { $cards } هستند.
draw-you-drew-cards = { $count } کارت جایگزین { $count ->
    [one] شما
   *[other] شما
} { $cards } هستند.
draw-you-draw = شما { $count } { $count ->
    [one] کارت
   *[other] کارت
} را تعویض می‌کنید.
draw-player-draws = { $player } { $count } { $count ->
    [one] کارت
   *[other] کارت
} را تعویض می‌کند.
draw-you-stand-pat = شما بدون تعویض می‌مانید و هر پنج کارت را نگه می‌دارید.
draw-player-stands-pat = { $player } بدون تعویض می‌ماند و هر پنج کارت را نگه می‌دارد.
draw-you-discard-limit = طبق قانون تعویض انتخاب‌شده، نمی‌توانید بیش از { $count } کارت را تعویض کنید.
draw-four-requires-kept-ace = تعویض ۴ کارت مستلزم نگهداشتن حداقل یک آس است. یک آس را لغو انتخاب کنید یا بیش از ۳ کارت را تعویض نکنید.

draw-raise-invalid = برای مبلغ افزایش، یک عدد صحیح بزرگتر از ۰ وارد کنید.
draw-raise-cap-reached = محدودیت { $count } افزایش در این دور شرط‌بندی قبلاً به‌دست آمده است. می‌توانید همراهی کنید یا کناره‌گیری کنید.
draw-raise-over-stack = شما سعی کردید { $requested } تراشه افزایش دهید، اما فقط { $chips } تراشه باقی‌مانده دارید. افزایش کمتری وارد کنید یا همه‌چیز را انتخاب کنید.
draw-raise-too-small = شما سعی کردید { $requested } تراشه افزایش دهید. حداقل افزایش { $minimum } تراشه است.
draw-raise-over-limit = شما سعی کردید { $requested } تراشه افزایش دهید. تحت { $mode ->
    [pot_limit] محدودیت پات
    [double_pot] محدودیت دوبرابر پات
   *[other] حالت افزایش انتخاب‌شده
}، بزرگ‌ترین افزایش موجود پس از همراهی { $maximum } تراشه است.
draw-all-in-over-limit = نمی‌توانید با { $stack } تراشه‌ی باقی‌مانده‌ی خود همه‌چیز بروید زیرا { $mode ->
    [pot_limit] محدودیت پات
    [double_pot] محدودیت دوبرابر پات
   *[other] حالت افزایش انتخاب‌شده
} در حال حاضر حداکثر { $maximum } تراشه افزایش را پس از همراهی مجاز می‌کند. برای وارد کردن مبلغ مجاز، از افزایش استفاده کنید.
draw-all-in-raise-cap-reached = نمی‌توانید به عنوان یک افزایش کامل همه‌چیز بروید زیرا محدودیت { $count } افزایش قبلاً به‌دست آمده است. می‌توانید همراهی کنید یا کناره‌گیری کنید.
draw-all-in-unavailable-raise-cap = همه‌چیز در دسترس نیست زیرا پس از رسیدن به محدودیت افزایش، یک افزایش کامل محسوب می‌شود. می‌توانید همراهی کنید یا کناره‌گیری کنید.
draw-all-in-unavailable-limit = همه‌چیز در دسترس نیست زیرا تراشه‌های شما از محدودیت شرط‌بندی فعلی بیشتر است. برای وارد کردن مبلغ مجاز، از افزایش استفاده کنید.
draw-raise-unavailable-cap = افزایش در دسترس نیست زیرا این دور شرط‌بندی به محدودیت افزایش خود رسیده است.
draw-raise-unavailable-limit = افزایش کامل با تراشه‌های شما و محدودیت شرط‌بندی فعلی در دسترس نیست. می‌توانید همراهی کنید، کناره‌گیری کنید، یا در صورت قانونی بودن از همه‌چیز استفاده کنید.

draw-current-bet = شرط فعلی میز { $amount } تراشه است.
draw-raise-range = حداقل افزایش { $minimum } تراشه است. پس از همراهی می‌توانید تا { $maximum } تراشه افزایش دهید.
draw-no-full-raise-available = برای همراهی به { $to_call } تراشه نیاز دارید و { $chips } تراشه باقی‌مانده دارید، بنابراین نمی‌توانید افزایش کامل انجام دهید. می‌توانید همه‌چیز را همراهی کنید یا کناره‌گیری کنید.
draw-dealer-unavailable = هنوز موقعیت فروشنده‌ای برای دست فعلی وجود ندارد.
draw-position-unavailable = شما در دست فعلی فعال نیستید، بنابراین موقعیت شرط‌بندی ندارید.

draw-card-key = کلید کارت { $index }

draw-winner-chips = { $rank }. { $player }: { $chips } { $chips ->
    [one] تراشه
   *[other] تراشه
}