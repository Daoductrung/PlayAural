game-name-lightturret = برج نور

lightturret-intro = برج نور با { $power } ظرفیت قدرت و { $rounds } دور کامل آغاز می‌شود. شلیک کنید تا نور و دو برابر آن سکه به دست آورید. برج تنها زمانی بیش‌بار می‌شود که نور از قدرت بیشتر شود. ارتقاء هسته { $cost } سکه هزینه دارد و ممکن است نتیجه‌ی عکس بدهد.
lightturret-intro-brief = برج نور: { $power } قدرت، { $rounds } دور، ارتقاء { $cost } سکه.
lightturret-round-start = دور { $round } از { $total } با { $alive } { $alive ->
    [one] برج فعال
   *[other] برج فعال
} آغاز می‌شود.
lightturret-round-start-brief = دور { $round }/{ $total }. فعال: { $alive }.

lightturret-shoot = شلیک برج
lightturret-shoot-safe-label = شلیک برج؛ { $headroom } ظرفیت امن
lightturret-shoot-risk-label = شلیک برج؛ { $risk }% ریسک بیش‌باری
lightturret-upgrade = ارتقاء هسته
lightturret-upgrade-label = ارتقاء هسته؛ هزینه { $cost } سکه، شما { $coins } دارید
lightturret-check-stats = مشاهده‌ی وضعیت برج

lightturret-you-shoot = شما شلیک می‌کنید و { $gain } نور به اضافه‌ی { $coins } سکه به دست می‌آورید. برج شما در { $light } از { $power } قدرت، با { $headroom } ظرفیت امن و { $total_coins } سکه است.
lightturret-player-shoots = { $player } شلیک می‌کند و { $gain } نور به اضافه‌ی { $coins } سکه به دست می‌آورد. برج او در { $light } از { $power } قدرت، با { $headroom } ظرفیت امن و { $total_coins } سکه است.
lightturret-you-shoot-brief = شما شلیک کردید: +{ $gain } نور، +{ $coins } سکه. نور { $light }/{ $power}; سکه‌ها { $total_coins }.
lightturret-player-shoots-brief = { $player } شلیک کرد: +{ $gain } نور، +{ $coins } سکه. نور { $light }/{ $power}; سکه‌ها { $total_coins }.

lightturret-you-shoot-overload = شما شلیک می‌کنید و { $gain } نور به اضافه‌ی { $coins } سکه به دست می‌آورید و به { $light } نور در برابر { $power } قدرت می‌رسید. شما { $overload } از ظرفیت بیشتر می‌روید و با { $total_coins } سکه‌ی باقی‌مانده حذف می‌شوید.
lightturret-player-shoots-overload = { $player } شلیک می‌کند و { $gain } نور به اضافه‌ی { $coins } سکه به دست می‌آورد و به { $light } نور در برابر { $power } قدرت می‌رسد. او { $overload } از ظرفیت بیشتر می‌رود و با { $total_coins } سکه‌ی باقی‌مانده حذف می‌شود.
lightturret-you-shoot-overload-brief = شما بیش‌بار شدید: +{ $gain } نور، { $light }/{ $power}، { $overload} بیشتر. حذف شدید.
lightturret-player-shoots-overload-brief = { $player } بیش‌بار شد: +{ $gain } نور، { $light }/{ $power}، { $overload} بیشتر. حذف شد.

lightturret-you-upgrade = شما { $cost } سکه خرج می‌کنید و هسته را { $gain } قدرت ارتقاء می‌دهید. برج شما اکنون در { $light } نور، { $power } قدرت، { $headroom } ظرفیت امن و { $coins } سکه است.
lightturret-player-upgrades = { $player } { $cost } سکه خرج می‌کند و هسته را { $gain } قدرت ارتقاء می‌دهد. برج او اکنون در { $light } نور، { $power } قدرت، { $headroom } ظرفیت امن و { $coins } سکه است.
lightturret-you-upgrade-brief = شما ارتقاء دادید: +{ $gain } قدرت. نور { $light }/{ $power}; سکه‌ها { $coins }.
lightturret-player-upgrades-brief = { $player } ارتقاء داد: +{ $gain } قدرت. نور { $light }/{ $power}; سکه‌ها { $coins }.

lightturret-you-upgrade-accident = شما { $cost } سکه خرج می‌کنید، اما هسته نتیجه‌ی عکس می‌دهد و { $gain } نور اضافه می‌کند. برج شما در { $light } از { $power } قدرت، با { $headroom } ظرفیت امن و { $coins } سکه است.
lightturret-player-upgrades-accident = { $player } { $cost } سکه خرج می‌کند، اما هسته نتیجه‌ی عکس می‌دهد و { $gain } نور اضافه می‌کند. برج او در { $light } از { $power } قدرت، با { $headroom } ظرفیت امن و { $coins } سکه است.
lightturret-you-upgrade-accident-brief = ارتقاء شما نتیجه‌ی عکس داد: +{ $gain } نور. نور { $light }/{ $power}; سکه‌ها { $coins }.
lightturret-player-upgrades-accident-brief = ارتقاء { $player } نتیجه‌ی عکس داد: +{ $gain } نور. نور { $light }/{ $power}; سکه‌ها { $coins }.

lightturret-you-upgrade-overload = شما { $cost } سکه خرج می‌کنید، اما هسته نتیجه‌ی عکس می‌دهد و { $gain } نور اضافه می‌کند. شما به { $light } نور در برابر { $power } قدرت می‌رسید، { $overload } از ظرفیت بیشتر می‌روید و با { $coins } سکه‌ی باقی‌مانده حذف می‌شوید.
lightturret-player-upgrades-overload = { $player } { $cost } سکه خرج می‌کند، اما هسته نتیجه‌ی عکس می‌دهد و { $gain } نور اضافه می‌کند. او به { $light } نور در برابر { $power } قدرت می‌رسد، { $overload } از ظرفیت بیشتر می‌رود و با { $coins } سکه‌ی باقی‌مانده حذف می‌شود.
lightturret-you-upgrade-overload-brief = ارتقاء بیش‌بار: +{ $gain } نور، { $light }/{ $power}، { $overload} بیشتر. حذف شدید.
lightturret-player-upgrades-overload-brief = ارتقاء بیش‌بار { $player }: +{ $gain } نور، { $light }/{ $power}، { $overload} بیشتر. حذف شد.

lightturret-action-resolving = اقدام برج شما در حال بررسی است. منتظر پایان صدا و نتیجه‌ی آن باشید.
lightturret-not-enough-coins = برای ارتقاء هسته به { $need } سکه نیاز دارید، اما شما { $have } سکه دارید.
lightturret-you-are-eliminated = برج شما بیش‌بار شده و شما حذف شده‌اید، بنابراین نمی‌توانید اقدام دیگری انجام دهید.
lightturret-confirm-risky-shot = شلیک در حال حاضر { $risk }% ریسک بیش‌باری در { $light } نور و { $power } قدرت دارد. برای تأیید، ظرف { $seconds } ثانیه دوباره شلیک کنید.

lightturret-status-round = دور { $round } از { $total }. برج‌های فعال: { $alive }.
lightturret-stats-alive = { $player}: { $light } نور، { $power } قدرت، { $headroom } ظرفیت امن، { $coins } سکه، ریسک بیش‌باری شلیک بعدی { $risk }%.
lightturret-stats-eliminated = { $player}: در { $light } نور در برابر { $power } قدرت حذف شد.

lightturret-end-max-rounds = همه‌ی { $total } دور کامل شدند. مجموع نهایی نور برنده را مشخص می‌کند.
lightturret-end-max-rounds-brief = { $total } دور کامل شد.
lightturret-end-all-eliminated = همه‌ی برج‌ها در طول دور { $round } بیش‌بار شدند. مجموع نهایی نور برنده را مشخص می‌کند.
lightturret-end-all-eliminated-brief = همه‌ی برج‌ها در دور { $round } بیش‌بار شدند.

lightturret-you-win = شما با { $light } نور و { $power } قدرت برنده شدید. { $survived ->
    [true] برج شما زنده ماند.
   *[false] مجموع نهایی نور شما با وجود بیش‌باری پیشتاز است.
}
lightturret-player-wins = { $player } با { $light } نور و { $power } قدرت برنده شد. { $survived ->
    [true] برج او زنده ماند.
   *[false] مجموع نهایی نور او با وجود بیش‌باری پیشتاز است.
}
lightturret-you-win-brief = شما برنده شدید: { $light } نور.
lightturret-player-wins-brief = { $player } برنده شد: { $light } نور.
lightturret-you-tie = شما با { $players } با { $light } نور در رتبه‌ی اول مساوی می‌شوید.
lightturret-players-tie = { $players } با { $light } نور در رتبه‌ی اول مساوی می‌شوند.
lightturret-you-tie-brief = شما با { $players} مساوی شدید: { $light } نور.
lightturret-players-tie-brief = تساوی: { $players}، { $light } نور.

lightturret-set-starting-power = قدرت اولیه: { $power }
lightturret-enter-starting-power = قدرت اولیه را وارد کنید:
lightturret-option-changed-power = قدرت اولیه روی { $power } تنظیم شد.
lightturret-desc-starting-power = ظرفیت اولیه‌ی بیش‌باری هر برج. نور برابر با قدرت ایمن است؛ فقط نور بیشتر از قدرت بیش‌بار می‌شود (پیش‌فرض ۱۰، محدوده ۵-۳۰).
lightturret-set-max-rounds = حداکثر دور: { $rounds }
lightturret-enter-max-rounds = حداکثر دور را وارد کنید:
lightturret-option-changed-rounds = حداکثر دور روی { $rounds } تنظیم شد.
lightturret-desc-max-rounds = تعداد دورهای کامل. هر برج فعال یک نوبت در دور نهایی دریافت می‌کند (پیش‌فرض ۵۰، محدوده ۱۰-۲۰۰).
lightturret-error-starting-power-invalid = قدرت اولیه باید بین { $min } و { $max } باشد؛ مقدار فعلی { $power } است.
lightturret-error-max-rounds-invalid = حداکثر دور باید بین { $min } و { $max } باشد؛ مقدار فعلی { $rounds } است.

lightturret-status-survived = فعال
lightturret-status-eliminated = حذف شد
lightturret-end-winner = برنده: { $player } با { $light } نور.
lightturret-end-tie = تساوی رتبه‌ی اول: { $players } با { $light } نور.
lightturret-line-format = { $rank }. { $player}: { $light } نور، { $power } قدرت، { $coins } سکه، { $status }