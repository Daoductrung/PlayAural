game-name-scopa = اسکوپا

scopa-initial-table = کارت‌های روی میز: { $cards }
scopa-no-initial-table = هیچ کارتی روی میز برای شروع نیست.
scopa-you-collect = شما { $cards } را با { $card } جمع‌آوری می‌کنید.
scopa-player-collects = { $player } { $cards } را با { $card } جمع‌آوری می‌کند.
scopa-you-capture = شما { $cards } را با { $card } می‌گیرید.
scopa-player-captures = { $player } { $cards } را با { $card } می‌گیرد.
scopa-you-capture-scopa = شما { $cards } را با { $card } می‌گیرید و یک اسکوپا کسب می‌کنید!
scopa-player-captures-scopa = { $player } { $cards } را با { $card } می‌گیرد و یک اسکوپا کسب می‌کند!
scopa-you-capture-clear = شما { $cards } را با { $card } می‌گیرید و میز را خالی می‌کنید.
scopa-player-captures-clear = { $player } { $cards } را با { $card } می‌گیرد و میز را خالی می‌کند.
scopa-you-put-down = شما { $card } را روی میز می‌گذارید.
scopa-player-puts-down = { $player } { $card } را روی میز می‌گذارد.
scopa-scopa-suffix = - اسکوپا!
scopa-clear-table-suffix = ، میز را خالی می‌کند.
scopa-remaining-cards = { $player } کارت‌های باقی‌مانده‌ی میز را می‌گیرد.
scopa-you-get-remaining-cards = شما کارت‌های باقی‌مانده‌ی میز را می‌گیرید: { $cards }.
scopa-player-gets-remaining-cards = { $player } کارت‌های باقی‌مانده‌ی میز را می‌گیرد: { $cards }.
scopa-you-instant-win = شما بلافاصله با یک اسکوپا برنده می‌شوید!
scopa-your-team-instant-win = تیم شما بلافاصله با یک اسکوپا برنده می‌شود!
scopa-instant-win = { $player } بلافاصله با یک اسکوپا برنده می‌شود!
scopa-scoring-round = دور امتیازدهی...
scopa-you-most-cards = شما ۱ امتیاز برای بیشترین کارت ({ $count } کارت) کسب می‌کنید.
scopa-your-team-most-cards = تیم شما ۱ امتیاز برای بیشترین کارت ({ $count } کارت) کسب می‌کند.
scopa-most-cards = { $player } ۱ امتیاز برای بیشترین کارت ({ $count } کارت) کسب می‌کند.
scopa-most-cards-tie = بیشترین کارت مساوی است - هیچ امتیازی تعلق نمی‌گیرد.
scopa-you-most-diamonds = شما ۱ امتیاز برای بیشترین خشت ({ $count } خشت) کسب می‌کنید.
scopa-your-team-most-diamonds = تیم شما ۱ امتیاز برای بیشترین خشت ({ $count } خشت) کسب می‌کند.
scopa-most-diamonds = { $player } ۱ امتیاز برای بیشترین خشت ({ $count } خشت) کسب می‌کند.
scopa-most-diamonds-tie = بیشترین خشت مساوی است - هیچ امتیازی تعلق نمی‌گیرد.
scopa-you-seven-diamonds = شما ۱ امتیاز برای هفت خشت کسب می‌کنید.
scopa-your-team-seven-diamonds = تیم شما ۱ امتیاز برای هفت خشت کسب می‌کند.
scopa-seven-diamonds = { $player } ۱ امتیاز برای هفت خشت کسب می‌کند.
scopa-you-seven-diamonds-multi = شما ۱ امتیاز برای بیشترین هفت خشت ({ $count } × هفت خشت) کسب می‌کنید.
scopa-your-team-seven-diamonds-multi = تیم شما ۱ امتیاز برای بیشترین هفت خشت ({ $count } × هفت خشت) کسب می‌کند.
scopa-seven-diamonds-multi = { $player } ۱ امتیاز برای بیشترین هفت خشت ({ $count } × هفت خشت) کسب می‌کند.
scopa-seven-diamonds-tie = هفت خشت مساوی است - هیچ امتیازی تعلق نمی‌گیرد.
scopa-you-most-sevens = شما ۱ امتیاز برای بیشترین هفت ({ $count } هفت) کسب می‌کنید.
scopa-your-team-most-sevens = تیم شما ۱ امتیاز برای بیشترین هفت ({ $count } هفت) کسب می‌کند.
scopa-most-sevens = { $player } ۱ امتیاز برای بیشترین هفت ({ $count } هفت) کسب می‌کند.
scopa-most-sevens-tie = بیشترین هفت مساوی است - هیچ امتیازی تعلق نمی‌گیرد.
scopa-you-primiera = شما ۱ امتیاز برای پریمیرا ({ $score } امتیاز) کسب می‌کنید.
scopa-your-team-primiera = تیم شما ۱ امتیاز برای پریمیرا ({ $score } امتیاز) کسب می‌کند.
scopa-primiera = { $player } ۱ امتیاز برای پریمیرا ({ $score } امتیاز) کسب می‌کند.
scopa-primiera-tie = پریمیرا مساوی است - هیچ امتیازی تعلق نمی‌گیرد.
scopa-primiera-none = هیچ‌کس در هر چهار خال کارت نگرفته است، بنابراین هیچ امتیاز پریمیرایی تعلق نمی‌گیرد.
scopa-you-napola = شما { $points } امتیاز برای ناپولا کسب می‌کنید.
scopa-your-team-napola = تیم شما { $points } امتیاز برای ناپولا کسب می‌کند.
scopa-napola = { $player } { $points } امتیاز برای ناپولا کسب می‌کند.

scopa-manual-select-prompt = باید انتخاب کنید کدام کارت‌ها را بگیرید.

scopa-capture-option = گرفتن { $cards }

scopa-error-conflict-escoba-asso = اسکوبا و آسو پیگلیا توتو نمی‌توانند همزمان فعال باشند.
scopa-error-conflict-instant-inverse = برد فوری با اسکوپا نمی‌تواند با حالت معکوس فعال شود.
scopa-error-conflict-instant-no-scopas = برد فوری با اسکوپا نمی‌تواند زمانی که اسکوپاها امتیاز ندارند فعال شود.

scopa-score-line-target-pending = { $player }: { $score }/{ $target } { $unit } (+{ $round_score } اسکوپای در انتظار { $pending_unit } در این دور)
scopa-score-line-pending = { $player }: { $score } { $unit } (+{ $round_score } اسکوپای در انتظار { $pending_unit } در این دور)
scopa-target-tie-continue = چند طرف با { $score } { $score ->
    [one] امتیاز
   *[other] امتیاز
} مساوی هستند، بنابراین اسکوپا فراتر از هدف { $target } { $target ->
    [one] امتیاز
   *[other] امتیاز
} ادامه می‌یابد تا تساوی شکسته شود.
scopa-round-scores = امتیازات دور:
scopa-round-score-line = { $player }: +{ $round_score } (مجموع: { $total_score })
scopa-table-empty = هیچ کارتی روی میز نیست.
scopa-no-such-card = هیچ کارتی در آن موقعیت وجود ندارد.
scopa-captured-count = شما { $count } کارت گرفته‌اید.

scopa-view-table = مشاهده‌ی میز
scopa-view-captured = مشاهده‌ی کارت‌های گرفته‌شده
scopa-view-table-card = مشاهده‌ی کارت میز { $index }
scopa-pause-timer = توقف زمان‌سنج

scopa-hint-match = -> { $card }
scopa-hint-multi = -> { $count } کارت

scopa-enter-target-score = امتیاز هدف را وارد کنید (۱-۱۲۱)
scopa-desc-target-score = امتیاز مورد نیاز برای بردن اسکوپا (پیش‌فرض ۱۱، محدوده ۱-۱۲۱).
scopa-set-cards-per-deal = کارت در هر پخش: { $cards }
scopa-enter-cards-per-deal = کارت در هر پخش را وارد کنید (۱-۱۰)
scopa-set-decks = تعداد دسته‌ها: { $decks }
scopa-enter-decks = تعداد دسته‌ها را وارد کنید (۱-۶)
scopa-toggle-escoba = اسکوبا (جمع تا ۱۵): { $enabled }
scopa-toggle-hints = نمایش راهنمای گرفتن: { $enabled }
scopa-set-mechanic = مکانیک اسکوپا: { $mechanic }
scopa-select-mechanic = مکانیک اسکوپا را انتخاب کنید
scopa-toggle-instant-win = برد فوری با اسکوپا: { $enabled }
scopa-desc-team-mode = بازی انفرادی یا اندازه‌های تیمی ثابت برای اسکوپا را انتخاب می‌کند.
scopa-toggle-team-scoring = جمع کردن کارت‌های تیم برای امتیازدهی: { $enabled }
scopa-toggle-inverse = حالت معکوس (رسیدن به هدف = حذف): { $enabled }
scopa-toggle-manual = انتخاب دستی گرفتن: { $enabled }
scopa-toggle-asso = آسو پیگلیا توتو (آس همه را می‌گیرد): { $enabled }
scopa-toggle-primiera = امتیازدهی سنتی پریمیرا: { $enabled }
scopa-toggle-napola = ناپولا (دنباله‌ی خشت): { $enabled }

scopa-option-changed-cards = کارت در هر پخش روی { $cards } تنظیم شد.
scopa-desc-cards-per-deal = تعداد کارت‌هایی که هر بازیکن در هر پخش اسکوپا دریافت می‌کند (پیش‌فرض ۳، محدوده ۱-۱۰).
scopa-option-changed-decks = تعداد دسته‌ها روی { $decks } تنظیم شد.
scopa-desc-number-of-decks = تعداد دسته‌های ۴۰ کارتی اسکوپا که با هم مخلوط می‌شوند (پیش‌فرض ۱، محدوده ۱-۶).
scopa-option-changed-escoba = اسکوبا { $enabled }.
scopa-desc-escoba = گرفتن را به قوانین اسکوبا تغییر می‌دهد، جایی که کارت بازی شده و کارت‌های گرفته‌شده‌ی میز باید جمعاً ۱۵ شوند.
scopa-option-changed-hints = راهنمای گرفتن { $enabled }.
scopa-desc-show-capture-hints = نشان می‌دهد که هر کارت دست کدام کارت‌های میز را می‌تواند بگیرد.
scopa-option-changed-mechanic = مکانیک اسکوپا روی { $mechanic } تنظیم شد.
scopa-desc-scopa-mechanic = امتیازدهی معمول، بدون امتیاز اسکوپا، یا فقط امتیاز اسکوپا را انتخاب می‌کند.
scopa-option-changed-instant = برد فوری با اسکوپا { $enabled }.
scopa-desc-instant-win-scopas = وقتی فعال باشد، یک اسکوپا معتبر بلافاصله بازی را به پایان می‌رساند. این نمی‌تواند با بدون اسکوپا یا اسکوپای معکوس ترکیب شود.
scopa-option-changed-team-scoring = امتیازدهی کارت تیم { $enabled }.
scopa-desc-team-card-scoring = کنترل می‌کند که آیا هم‌تیمی‌ها کارت‌های گرفته‌شده را برای امتیازدهی پایان دور ترکیب می‌کنند یا نه. اگر در بازی تیمی غیرفعال باشد، کارت‌های هر بازیکن به‌طور جداگانه ارزیابی می‌شوند و هر امتیاز به تیم آن بازیکن اضافه می‌شود.
scopa-option-changed-inverse = حالت معکوس { $enabled }.
scopa-desc-inverse-scopa = هدف را معکوس می‌کند تا رسیدن به امتیاز هدف یک بازیکن یا تیم را حذف کند.
scopa-option-changed-manual = انتخاب دستی گرفتن { $enabled }.
scopa-desc-manual-selection = به بازیکنان اجازه می‌دهد در صورت وجود بیش از یک گرفتن قانونی، یک ترکیب گرفتن را به‌صورت دستی انتخاب کنند.
scopa-option-changed-asso = آسو پیگلیا توتو { $enabled }.
scopa-desc-asso-piglia-tutto = آس همه را می‌گیرد: یک آس میز را جارو می‌کند و یک اسکوپا امتیاز می‌گیرد مگر اینکه آس دیگری قبلاً روی میز باشد. این نمی‌تواند با اسکوبا ترکیب شود.
scopa-option-changed-primiera = امتیازدهی سنتی پریمیرا { $enabled }.
scopa-desc-primiera-scoring = امتیازدهی سنتی پریمیرا را فعال می‌کند؛ وقتی خاموش باشد، بازی از نسخه‌ی ساده‌تر بیشترین هفت استفاده می‌کند.
scopa-option-changed-napola = ناپولا { $enabled }.
scopa-desc-napola = امتیازات پاداش برای گرفتن یک دنباله‌ی پیوسته‌ی خشت که با آس شروع می‌شود، اعطا می‌کند.

scopa-mechanic-normal = معمولی
scopa-mechanic-no_scopas = بدون اسکوپا
scopa-mechanic-only_scopas = فقط اسکوپا

scopa-timer-not-active = زمان‌سنج دور فعال نیست.

scopa-error-not-enough-cards = کارت‌های کافی در { $decks } { $decks ->
    [one] دسته
   *[other] دسته
} برای { $players } { $players ->
    [one] بازیکن
   *[other] بازیکن
} با { $cards_per_deal } کارت برای هر نفر وجود ندارد. (به { $cards_per_deal } × { $players } = { $cards_needed } کارت نیاز است، اما فقط { $total_cards } کارت وجود دارد.)

scopa-line-format = { $rank }. { $player }: { $points }