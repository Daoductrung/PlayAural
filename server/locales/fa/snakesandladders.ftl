game-name-snakesandladders = مار و پله
game-snakesandladders-desc = مسابقه از منطقه‌ی شروع تا خانه‌ی ۱۰۰. از نردبان‌ها بالا بروید، از مارها پایین بیایید و اولین نفری باشید که به خط پایان می‌رسد.

snakes-roll = پرتاب تاس
snakes-check-positions = بررسی موقعیت‌ها

snakes-turn-start-you = نوبت شما. مهره‌ی شما در منطقه‌ی شروع قبل از خانه‌ی ۱ است.
snakes-turn-start-other = نوبت { $player }. مهره‌ی او در منطقه‌ی شروع قبل از خانه‌ی ۱ است.
snakes-turn-you = نوبت شما. شما در خانه‌ی { $position } هستید.
snakes-turn-other = نوبت { $player }. او در خانه‌ی { $position } است.

snakes-roll-you = شما { $roll } انداختید.
snakes-roll-other = { $player } { $roll } انداخت.
snakes-enter-you = شما از منطقه‌ی شروع به خانه‌ی { $position } حرکت می‌کنید.
snakes-enter-other = { $player } از منطقه‌ی شروع به خانه‌ی { $position } حرکت می‌کند.
snakes-enter-you-brief = شما: خانه‌ی { $position }.
snakes-enter-other-brief = { $player }: خانه‌ی { $position }.
snakes-move-you = شما { $roll } خانه از خانه‌ی { $start } به خانه‌ی { $position } حرکت می‌کنید.
snakes-move-other = { $player } { $roll } خانه از خانه‌ی { $start } به خانه‌ی { $position } حرکت می‌کند.
snakes-move-you-brief = شما: خانه‌ی { $position }.
snakes-move-other-brief = { $player }: خانه‌ی { $position }.
snakes-bounce-you = از خانه‌ی { $start }، پرتاب { $roll } شما از خانه‌ی { $target } عبور می‌کند، بنابراین از خط پایان به خانه‌ی { $position } بازمی‌گردید.
snakes-bounce-other = از خانه‌ی { $start }، { $player } { $roll } می‌اندازد، از خانه‌ی { $target } عبور می‌کند و از خط پایان به خانه‌ی { $position } بازمی‌گردد.
snakes-bounce-you-brief = شما به خانه‌ی { $position } بازگشتید.
snakes-bounce-other-brief = { $player } به خانه‌ی { $position } بازگشت.
snakes-restored-bounce-you = پرتاب ذخیره‌شده‌ی شما با بازگشت به خانه‌ی { $position } به پایان می‌رسد.
snakes-restored-bounce-other = پرتاب ذخیره‌شده‌ی { $player } با بازگشت او به خانه‌ی { $position } به پایان می‌رسد.
snakes-exact-miss-you = برای رسیدن به خانه‌ی { $target } به { $needed } نیاز دارید، اما { $roll } انداختید، بنابراین در خانه‌ی { $position } می‌مانید.
snakes-exact-miss-other = { $player } برای رسیدن به خانه‌ی { $target } به { $needed } نیاز دارد، اما { $roll } می‌اندازد، بنابراین در خانه‌ی { $position } می‌ماند.
snakes-exact-miss-you-brief = به { $needed } نیاز دارید، { $roll } انداختید و در خانه‌ی { $position } ماندید.
snakes-exact-miss-other-brief = { $player } به { $needed } نیاز دارد، { $roll } می‌اندازد و در خانه‌ی { $position } می‌ماند.
snakes-ladder-you = شما در پای نردبان در خانه‌ی { $start } فرود می‌آیید و به خانه‌ی { $end } بالا می‌روید و { $distance } خانه جلو می‌افتید.
snakes-ladder-other = { $player } در پای نردبان در خانه‌ی { $start } فرود می‌آید و به خانه‌ی { $end } بالا می‌رود و { $distance } خانه جلو می‌افتد.
snakes-ladder-you-brief = شما از خانه‌ی { $start } به { $end } بالا رفتید.
snakes-ladder-other-brief = { $player } از خانه‌ی { $start } به { $end } بالا رفت.
snakes-snake-you = شما روی سر مار در خانه‌ی { $start } فرود می‌آیید و به دم آن در خانه‌ی { $end } می‌لغزید و { $distance } خانه عقب می‌افتید.
snakes-snake-other = { $player } روی سر مار در خانه‌ی { $start } فرود می‌آید و به دم آن در خانه‌ی { $end } می‌لغزد و { $distance } خانه عقب می‌افتد.
snakes-snake-you-brief = شما از خانه‌ی { $start } به { $end } لغزیدید.
snakes-snake-other-brief = { $player } از خانه‌ی { $start } به { $end } لغزید.
snakes-extra-turn-you = شما ۶ انداختید، بنابراین از خانه‌ی { $position } یک نوبت دیگر می‌گیرید.
snakes-extra-turn-other = { $player } ۶ انداخت، بنابراین از خانه‌ی { $position } یک نوبت دیگر می‌گیرد.
snakes-win-you = شما به خانه‌ی { $position } رسیدید و بازی را برنده شدید!
snakes-win-other = { $player } به خانه‌ی { $position } رسید و بازی را برنده شد!

snakes-status-goal = هدف: خانه‌ی { $target }. قانون پایان: { $rule }.
snakes-status-current-start = { $player }: منطقه‌ی شروع قبل از خانه‌ی ۱. نوبت فعلی.
snakes-status-player-start = { $player }: منطقه‌ی شروع قبل از خانه‌ی ۱.
snakes-status-current-position = { $player }: خانه‌ی { $position }، { $remaining } خانه باقی‌مانده. نوبت فعلی.
snakes-status-player-position = { $player }: خانه‌ی { $position }، { $remaining } خانه باقی‌مانده.
snakes-status-player-finished = { $player }: خانه‌ی { $position }، به پایان رسید.

snakes-finish-bounce-back = بازگشت به عقب
snakes-finish-exact-stay = پرتاب دقیق؛ پس از عبور از هدف در جای خود بمانید
snakes-set-finish-rule = قانون پایان: { $rule }
snakes-select-finish-rule = قانون پایان را انتخاب کنید
snakes-option-changed-finish-rule = قانون پایان به { $rule } تغییر یافت.
snakesandladders-desc-finish-rule = انتخاب می‌کند که عبور از خانه‌ی ۱۰۰ به عقب بازگردد یا بازیکن را برای پرتاب دقیق منتظر بگذارد.
snakes-set-extra-turn-six = نوبت اضافی با ۶: { $enabled }
snakes-option-changed-extra-turn-six = نوبت اضافی با ۶ به { $enabled } تغییر یافت.
snakesandladders-desc-extra-turn-on-six = کنترل می‌کند که آیا پرتاب ۶ یک نوبت اضافی می‌دهد یا نه.

snakes-error-roll-not-playing = فقط پس از شروع بازی مار و پله می‌توانید تاس بیندازید.
snakes-error-roll-not-your-turn = نمی‌توانید هنوز تاس بیندازید چون بازیکن دیگری در حال انجام نوبت خود است. منتظر بمانید تا نوبت به شما برسد.
snakes-error-roll-resolving = پرتاب تاس قبلی شما هنوز در حال بررسی است. منتظر پایان دنباله‌ی حرکت، مار یا نردبان باشید تا دوباره پرتاب کنید.
snakes-error-positions-not-playing = موقعیت‌ها فقط در حین اجرای بازی مار و پله در دسترس هستند.
snakes-error-invalid-finish-rule = قانون پایان انتخاب‌شده، { $rule }، پشتیبانی نمی‌شود. بازگشت به عقب یا پرتاب دقیق؛ پس از عبور از هدف در جای خود بمانید را انتخاب کنید.

snakes-end-score = { $rank }. { $player }: خانه‌ی { $position }
snakes-end-score-start = { $rank }. { $player }: منطقه‌ی شروع قبل از خانه‌ی ۱