game-name-tradeoff = مبادله

tradeoff-round-start = دور { $round }.
tradeoff-iteration = دست { $iteration } از ۳.

tradeoff-you-rolled = شما پرتاب کردید: { $dice }.
tradeoff-toggle-trade = { $value } ({ $status })
tradeoff-trade-status-trading = در حال مبادله
tradeoff-trade-status-keeping = نگهداری
tradeoff-confirm-trades = تأیید مبادلات ({ $count } تاس)
tradeoff-keeping = نگهداری { $value }.
tradeoff-trading = مبادله‌ی { $value }.
tradeoff-you-traded = شما { $count } تاس را به استخر مبادله کردید: { $dice }.
tradeoff-player-traded = { $player } { $count } تاس را به استخر مبادله کرد: { $dice }.
tradeoff-you-traded-brief = شما { $count } تاس مبادله کردید.
tradeoff-player-traded-brief = { $player } { $count } تاس مبادله کرد.
tradeoff-you-traded-none = شما هر پنج تاس این دست را نگه داشتید، بنابراین این بار از استخر چیزی نمی‌گیرید.
tradeoff-player-traded-none = { $player } هر پنج تاس این دست را نگه داشت.

tradeoff-your-turn-take = نوبت شما برای برداشتن یک تاس از استخر.
tradeoff-take-die = برداشتن یک { $value } ({ $remaining } باقی‌مانده)
tradeoff-you-take = شما یک { $value } برمی‌دارید.
tradeoff-player-takes = { $player } یک { $value } برمی‌دارد.

tradeoff-you-scored = شما با { $sets }، { $points } امتیاز کسب کردید.
tradeoff-player-scored = { $player } با { $sets }، { $points } امتیاز کسب کرد.
tradeoff-you-scored-brief = شما در این دور { $points } امتیاز کسب کردید.
tradeoff-player-scored-brief = { $player } در این دور { $points } امتیاز کسب کرد.
tradeoff-you-no-sets = شما ۰ امتیاز کسب کردید چون ۱۵ تاس شما هیچ مجموعه‌ی امتیازی تشکیل نداد.
tradeoff-no-sets = { $player } ۰ امتیاز کسب کرد چون ۱۵ تاس او هیچ مجموعه‌ی امتیازی تشکیل نداد.

tradeoff-set-triple = سه‌تایی از { $value }
tradeoff-set-group = گروهی از { $value }
tradeoff-set-mini-straight = دنباله‌ی کوچک { $low }-{ $high }
tradeoff-set-double-triple = دو سه‌تایی ({ $v1 } و { $v2 })
tradeoff-set-straight = دنباله { $low }-{ $high }
tradeoff-set-double-group = دو گروه ({ $v1 } و { $v2 })
tradeoff-set-all-groups = همه‌ی گروه‌ها
tradeoff-set-all-triplets = همه‌ی سه‌تایی‌ها

tradeoff-round-scores = امتیازات دور { $round }:
tradeoff-round-scores-brief = امتیازات:
tradeoff-score-line = { $player }: +{ $round_points } (مجموع: { $total })
tradeoff-score-line-brief = { $player}: +{ $round_points }، مجموع { $total }.
tradeoff-leader = { $player } با { $score } پیشتاز است.
tradeoff-leader-brief = پیشتاز: { $player }، { $score }.

tradeoff-you-win = شما با { $score } امتیاز برنده شدید!
tradeoff-winner = { $player } با { $score } امتیاز برنده شد!
tradeoff-you-tie-win = شما با { $players } با { $score } امتیاز در برد مساوی شدید!
tradeoff-winners-tie = تساوی! { $players } با { $score } امتیاز مساوی شدند!

tradeoff-view-hand = مشاهده‌ی دست خود
tradeoff-view-pool = مشاهده‌ی استخر
tradeoff-view-players = مشاهده‌ی بازیکنان
tradeoff-hand-state-empty = هنوز تاسی نگهداری نشده
tradeoff-hand-empty = دست نگهداری‌شده‌ی شما خالی است. اگر تازه پرتاب کرده‌اید، از گزینه‌های تاس برای تصمیم‌گیری درباره‌ی نگهداری قبل از تأیید مبادلات استفاده کنید.
tradeoff-hand-display = دست نگهداری‌شده‌ی شما در این دور ({ $count } تاس): { $dice }.
tradeoff-hand-display-with-roll = دست نگهداری‌شده‌ی شما در این دور ({ $count } تاس): { $dice }. پرتاب فعلی: { $roll }. { $trade_count } تاس هنوز برای مبادله علامت‌گذاری شده‌اند.
tradeoff-roll-die-status = موقعیت { $position}: { $value }، { $status }
tradeoff-die-count = { $value}: { $count }
tradeoff-pool-display = استخر ({ $count } تاس): { $dice }.
tradeoff-pool-empty = استخر خالی است.
tradeoff-player-info = { $player}: دست نگهداری‌شده: { $hand }. آخرین مبادله: { $traded }.
tradeoff-player-info-no-trade = { $player}: دست نگهداری‌شده: { $hand }. آخرین مبادله: هیچ.

tradeoff-not-trading-phase = فقط زمانی که تاس‌های تازه پرتاب‌شده‌ی شما در مرحله‌ی مبادله در انتظار هستند، می‌توانید گزینه‌های مبادله را تغییر یا تأیید کنید.
tradeoff-not-taking-phase = فقط پس از تأیید مبادلات توسط همه‌ی بازیکنان و باز شدن استخر مشترک، می‌توانید تاس بردارید.
tradeoff-already-confirmed = شما قبلاً این انتخاب مبادله را تأیید کرده‌اید. منتظر سایر بازیکنان باشید؛ اگر تاس مبادله کرده‌اید، وقتی نوبت شما رسید از استخر خواهید گرفت.
tradeoff-no-die = هیچ تاسی برای آن اقدام مبادله در دسترس نیست.
tradeoff-no-die-position = موقعیت { $position } در پرتاب فعلی شما در دسترس نیست.
tradeoff-no-rolled-dice = شما در حال حاضر تاس پرتاب‌شده‌ای برای انتخاب مبادله در انتظار ندارید.
tradeoff-no-more-takes = شما قبلاً به تعداد تاس‌هایی که در این دست مبادله کرده‌اید، پس گرفتید.
tradeoff-not-in-pool = در حال حاضر هیچ { $value } در استخر مشترک وجود ندارد. به جای آن یکی از مقادیر قابل مشاهده‌ی استخر را انتخاب کنید.
tradeoff-not-your-take-turn = نوبت { $player } برای برداشتن از استخر است. قبل از انتخاب تاس، منتظر اعلام نام خود باشید.
tradeoff-no-trading-die-value = شما در حال حاضر هیچ { $value } علامت‌گذاری‌شده برای مبادله ندارید.
tradeoff-no-kept-die-value = شما هیچ { $value } نگهداری‌شده‌ای برای علامت‌گذاری مبادله ندارید.
tradeoff-value-trade-style-required = کنترل‌های مبادله با Shift+عدد فقط با شیوه‌ی نگهداری مقدار تاس‌ها استفاده می‌شود. از کلیدهای عدد ساده بر اساس موقعیت استفاده کنید، یا شیوه‌ی نگهداری تاس شخصی خود را تغییر دهید.
tradeoff-use-plain-number-to-take = برای برداشتن تاس از استخر، از کلید عدد ساده استفاده کنید، نه Shift+عدد.
tradeoff-no-dice-key-phase = کلیدهای عدد فقط هنگام انتخاب مبادلات یا برداشتن تاس از استخر استفاده می‌شوند.

tradeoff-set-target = امتیاز هدف: { $score }
tradeoff-enter-target = امتیاز هدف را وارد کنید:
tradeoff-option-changed-target = امتیاز هدف روی { $score } تنظیم شد.
tradeoff-desc-target-score = مجموع امتیازی که یک بازیکن باید پس از یک دور امتیازدهی به آن برسد یا از آن عبور کند تا برنده شود (پیش‌فرض ۶۰، محدوده ۳۰-۵۰۰).
tradeoff-error-target-out-of-range = امتیاز هدف { $score } خارج از محدوده‌ی مجاز { $min } تا { $max } است.